SECRET_KEY=change_me
SESSION_COOKIE_SECURE=0
APP_ENV=production

# PostgreSQL is required
DATABASE_URL=postgresql://fabouanes:password@localhost:5432/fabouanes
DB_POOL_SIZE=20
DB_POOL_TIMEOUT_SECONDS=8

# Optional Redis cache (leave empty to disable)
# REDIS_URL=redis://localhost:6379/0

# API docs (Swagger/OpenAPI)
API_DOCS_ENABLED=1
API_DOCS_PATH=/api/docs
API_OPENAPI_PATH=/api/openapi.json
API_REDOC_PATH=/api/redoc

# CORS / API security
CORS_ALLOW_ALL=0
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1

# Structured logs
LOG_LEVEL=INFO

# Web pagination guardrails
WEB_PAGE_SIZE=100
WEB_MAX_PAGE_SIZE=500

# Example Docker Compose URL:
# DATABASE_URL=postgresql://fabouanes:fabouanes_change_me@localhost:5432/fabouanes

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe!234
