# ============================================================
# SECRET_KEY — OBLIGATOIRE EN PRODUCTION
# ============================================================
# Generez une cle forte avec:
#   python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT : ne jamais laisser vide en production.
# Si vide, une cle est auto-generee et sauvegardee dans AppData/FABOuanes/secret.key
# Si ce fichier est perdu, TOUTES les sessions utilisateurs seront invalidees.
SECRET_KEY=
# Set to 1 when serving over HTTPS outside desktop/local development.
SESSION_COOKIE_SECURE=0

# Base de donnees — SQLite autonome (mode WAL).
# Par defaut, le fichier fabouanes.db est cree automatiquement dans AppData/Local/FABOuanes/
# Vous pouvez personnaliser le chemin si besoin (optionnel) :
# DATABASE_URL=sqlite+aiosqlite:///C:/Users/votre_nom/AppData/Local/FABOuanes/fabouanes.db

# Reseau - par defaut, les autres machines du meme reseau peuvent se connecter.
FAB_HOST=0.0.0.0
FAB_PORT=5000

# Runtime production: un seul worker tant que le cache/scheduler restent in-process.
WEB_CONCURRENCY=1
FAB_CACHE_MAX_ENTRIES=512

DEFAULT_ADMIN_USERNAME=admin
# Leave empty to generate a first-launch PIN in AppData/FABOuanes/first_admin_password.txt.
DEFAULT_ADMIN_PASSWORD=

# --- Securite ---
# Mode de validation des mots de passe:
#   'pin'      — 4 chiffres exactement (usage interne/desktop uniquement)
#   'password' — 8+ caracteres avec lettre et chiffre (recommande en production serveur)
# IMPORTANT : en production exposee sur le reseau, utiliser 'password'.
FAB_PASSWORD_MODE=pin

# AVERTISSEMENT RESEAU : si vous utilisez LANCER_ANDROID_RESEAU.bat,
# l'application est accessible depuis d'autres machines du reseau local.
# Ne jamais combiner FAB_DESKTOP=1 avec un acces reseau en production.

# --- Logging ---
# Activer le logging structure JSON pour la production (0 = texte classique, 1 = JSON)
FAB_LOG_JSON=0

# --- Modules ---
# Desactiver des modules specifiques (separes par des virgules)
# FAB_MODULES_DISABLED=expenses,reports

# --- Rate Limiting ---
# Choix du stockage du rate limiting : 'memory' (par défaut en mémoire locale) ou 'db' (table SQLite locale).
FAB_RATE_LIMIT_BACKEND=memory

# --- OpenTelemetry (Observabilité) ---
# En production, les traces sont envoyées à la console par défaut.
# Pour envoyer les traces à un collecteur OTLP (Jaeger, Grafana Tempo, etc.):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# En développement, activer la console manuellement:
# OTEL_EXPORT_CONSOLE=true
