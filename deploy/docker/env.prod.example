# ============================================================
# FABouanes - CONFIGURATION DE PRODUCTION
# ============================================================

# 1. Clé secrète de session - OBLIGATOIRE ET CRITIQUE
# Générez une clé robuste avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 2. Sécurité du Cookie de session (1 = HTTPS uniquement)
# Doit être défini à 1 si vous utilisez un proxy inverse SSL (ex: Nginx, Traefik).
SESSION_COOKIE_SECURE=1

# 3. Identifiants de la base de données PostgreSQL
# À utiliser par docker-compose pour le conteneur PostgreSQL
# IMPORTANT : Choisissez un mot de passe robuste et complexe !
POSTGRES_PASSWORD=

# 4. Port d'écoute externe de l'application web
FAB_PORT=8000

# 5. Identifiants de l'administrateur par défaut au premier démarrage
# Laissez vide pour générer un code PIN temporaire au démarrage.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# 6. Clé API de Sabrina (Gemini)
# Vous pouvez aussi la configurer plus tard directement depuis l'interface admin.
GEMINI_API_KEY=

# 7. Paramètres de performances et base de données
WEB_CONCURRENCY=1
FAB_PG_POOL_SIZE=15
FAB_PG_POOL_MAX_OVERFLOW=10
FAB_SLOW_SQL_MS=100
FAB_REQUEST_TIMEOUT_SECONDS=30
